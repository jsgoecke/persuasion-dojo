# Required
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Required if using Google Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional
# DATABASE_URL=sqlite+aiosqlite:////app/data/db/persuasion_dojo.db
# DATABASE_ECHO=0
# TURN_TRACKER_ENABLED=true

# Port the backend binds for the Swift audio TCP transport (loopback only).
# Swift reads AUDIO_BACKEND_PORT with the same value; Electron forwards it
# automatically.
AUDIO_TCP_PORT=9090
